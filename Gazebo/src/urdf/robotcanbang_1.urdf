<!-- This URDF was automatically created by SolidWorks to URDF Exporter! Originally created by Stephen Brawner (brawner@gmail.com) 
     Commit Version: 1.6.0-4-g7f85cfe  Build Version: 1.6.7995.38578
     For more information, please see http://wiki.ros.org/sw_urdf_exporter -->
<!-- Modified for Gazebo simulation with LQR balance control -->
<robot name="robotcanbang">
  
  <!-- Base Link - Main Body -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.0248084517338711 0.00310273352138043 0.0968723741633463" rpy="0 0 0" />
      <mass value="0.406163631736865" />
      <inertia
        ixx="0.000461069610454791"
        ixy="-2.8857514269128E-10"
        ixz="7.01700491225405E-05"
        iyy="0.000640210694979862"
        iyz="1.7426442216153E-09"
        izz="0.000717621199840196" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <inertial>
      <origin xyz="-5.34068539392862E-10 6.0839499302183E-10 0.00471009224884603" rpy="0 0 0" />
      <mass value="0.035174827698133" />
      <inertia
        ixx="1.52368231801454E-05"
        ixy="3.9005394908129E-10"
        ixz="-4.70997363357401E-14"
        iyy="1.52374393452278E-05"
        iyz="6.5076142600852E-14"
        izz="2.57858861550236E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/right_wheel.STL" />
      </geometry>
      <material name="">
        <color rgba="0.333333333333333 0.333333333333333 0.333333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/right_wheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="0 0.10003 0.0325" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="right_wheel" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="100" />
  </joint>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <inertial>
      <origin xyz="1.11657100232421E-10 -8.01833147405159E-10 0.00153990775115411" rpy="0 0 0" />
      <mass value="0.0351748276981331" />
      <inertia
        ixx="1.52375621811932E-05"
        ixy="-2.47721973242754E-10"
        ixz="-1.84932170636715E-14"
        iyy="1.52367003441801E-05"
        iyz="7.81747652153319E-14"
        izz="2.57858861550237E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/left_wheel.STL" />
      </geometry>
      <material name="">
        <color rgba="0.333333333333333 0.333333333333333 0.333333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robotcanbang_1/meshes/left_wheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="0 -0.10003 0.0325" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="left_wheel" />
    <axis xyz="0 0 -1" />
    <limit effort="100" velocity="100" />
  </joint>

  <!-- ==================== GAZEBO ELEMENTS ==================== -->

  <!-- Gazebo Material Colors -->
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- IMU Sensor Plugin -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <topicName>imu/data</topicName>
        <bodyName>base_link</bodyName>
        <updateRateHZ>100.0</updateRateHZ>
        <gaussianNoise>0.0</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
        <frameName>base_link</frameName>
      </plugin>
      <pose>0 0 0.1 0 0 0</pose>
    </sensor>
  </gazebo>

  <!-- Gazebo ROS Control Plugin -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
    </plugin>
  </gazebo>

  <!-- Transmissions for ROS Control -->
  <transmission name="right_wheel_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="right_wheel_joint">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="right_wheel_motor">
      <mechanicalReduction>1</mechanicalReduction>
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </actuator>
  </transmission>

  <transmission name="left_wheel_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_wheel_joint">
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="left_wheel_motor">
      <mechanicalReduction>1</mechanicalReduction>
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </actuator>
  </transmission>

</robot>
